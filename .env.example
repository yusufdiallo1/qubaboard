# ─────────────────────────────────────────────────────────────
# Supabase  (Project Settings → API)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only. Never expose to the browser. Used for admin scripts/seed.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ─────────────────────────────────────────────────────────────
# AI description auto-translate (Arabic <-> English)
# Pick ONE. Groq is cheap + fast (recommended for production).
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=YOUR-GROQ-KEY
# ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deep-link to the separate Issue & Maintenance Tracker project (optional)
NEXT_PUBLIC_ISSUE_TRACKER_URL=https://aurionfix.vercel.app
